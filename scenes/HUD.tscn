[gd_scene load_steps=3 format=3 uid="uid://hud_scene"]

[ext_resource type="Script" path="res://scripts/UI.gd" id="1_ui"]
[ext_resource type="Script" path="res://scripts/SpellMeter.gd" id="2_meter"]

[node name="HUD" type="CanvasLayer"]
script = ExtResource("1_ui")

[node name="TopBar" type="HBoxContainer" parent="."]
anchors_preset = 10
anchor_right = 1.0
offset_bottom = 40.0
grow_horizontal = 2
theme_override_constants/separation = 20

[node name="ScoreLabel" type="Label" parent="TopBar" node_paths=PackedStringArray()]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
text = "SCORE: 000000"
theme_override_colors/font_color = Color(1, 0.8, 0.2, 1)

[node name="LifeIcons" type="HBoxContainer" parent="TopBar"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/separation = 8

[node name="Life1" type="Label" parent="TopBar/LifeIcons"]
layout_mode = 2
text = "♥"
theme_override_colors/font_color = Color(1, 0.2, 0.2, 1)

[node name="Life2" type="Label" parent="TopBar/LifeIcons"]
layout_mode = 2
text = "♥"
theme_override_colors/font_color = Color(1, 0.2, 0.2, 1)

[node name="Life3" type="Label" parent="TopBar/LifeIcons"]
layout_mode = 2
text = "♥"
theme_override_colors/font_color = Color(1, 0.2, 0.2, 1)

[node name="RankGem" type="Label" parent="TopBar"]
layout_mode = 2
text = "◆"
theme_override_colors/font_color = Color(0.4, 0.8, 1, 1)

[node name="SpellMeter" type="Control" parent="."]
unique_name_in_owner = true
anchors_preset = 1
anchor_left = 1.0
anchor_right = 1.0
offset_left = -80.0
offset_top = 50.0
offset_right = -10.0
offset_bottom = 120.0
script = ExtResource("2_meter")

[node name="MeterLabel" type="Label" parent="SpellMeter"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
text = "SPELL"
horizontal_alignment = 1
vertical_alignment = 1
theme_override_colors/font_color = Color(0.8, 0.6, 1, 1)
theme_override_font_sizes/font_size = 10

[node name="BottomBar" type="HBoxContainer" parent="."]
anchors_preset = 12
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = -36.0
grow_horizontal = 2
grow_vertical = 0

[node name="LevelNameLabel" type="Label" parent="BottomBar"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
text = "ALCHEMICAL LABS"
horizontal_alignment = 1
theme_override_colors/font_color = Color(1, 0.6, 0.2, 1)

[node name="PauseMenu" type="PanelContainer" parent="."]
unique_name_in_owner = true
visible = false
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -120.0
offset_top = -100.0
offset_right = 120.0
offset_bottom = 100.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="PauseMenu"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="PauseMenu/VBox"]
layout_mode = 2
text = "PAUSED"
horizontal_alignment = 1
theme_override_colors/font_color = Color(1, 0.8, 0.2, 1)
theme_override_font_sizes/font_size = 24

[node name="ResumeButton" type="Button" parent="PauseMenu/VBox"]
layout_mode = 2
text = "Resume"

[node name="RestartButton" type="Button" parent="PauseMenu/VBox"]
layout_mode = 2
text = "Restart"

[node name="QuitButton" type="Button" parent="PauseMenu/VBox"]
layout_mode = 2
text = "Quit"

[node name="LorePopup" type="PanelContainer" parent="."]
unique_name_in_owner = true
visible = false
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -80.0
offset_right = 200.0
offset_bottom = 80.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="LorePopup"]
layout_mode = 2
theme_override_constants/separation = 16

[node name="LoreText" type="Label" parent="LorePopup/VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "Lore text here..."
horizontal_alignment = 1
autowrap_mode = 2
theme_override_colors/font_color = Color(1, 0.9, 0.7, 1)

[node name="ContinueButton" type="Button" parent="LorePopup/VBox"]
layout_mode = 2
text = "Continue"

[connection signal="pressed" from="PauseMenu/VBox/ResumeButton" to="." method="_on_resume_button_pressed"]
[connection signal="pressed" from="PauseMenu/VBox/RestartButton" to="." method="_on_restart_button_pressed"]
[connection signal="pressed" from="PauseMenu/VBox/QuitButton" to="." method="_on_quit_button_pressed"]
[connection signal="pressed" from="LorePopup/VBox/ContinueButton" to="." method="_on_continue_button_pressed"]
